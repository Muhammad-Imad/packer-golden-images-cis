# Packer build artifacts & manifests (keep the dir, drop the outputs)
manifests/*.json
*.manifest.json

# Local crash / plugin state
packer_cache/
crash.log
crash.*.log

# Locally pinned plugin versions (regenerated by `packer init`)
.packer.d/
*.pkrplugin

# User-specific variable files — never commit real account IDs / keys
*.auto.pkrvars.hcl
*.local.pkrvars.hcl
prod.pkrvars.hcl
secret*.pkrvars.hcl

# Credentials / keys that must never be committed
*.pem
*.pub
*.ppk
.env
.env.*
credentials
aws-credentials*

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
